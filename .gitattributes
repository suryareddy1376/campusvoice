# Normalize line endings for cross-platform consistency
* text=auto

# JavaScript / JSON — keep LF
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env*  text eol=lf

# Windows scripts — keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
